# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Base URL for internal API calls (e.g. the Masidy engine route).
# For Vercel deployments use your project URL; for local dev use http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://your-vercel-domain.vercel.app

# ── Masidy Custom ──────────────────────────────────────────────────────────────
GROQ_API_KEY=****              # Free Llama 3.1 8B inference
LANGSEARCH_API_KEY=****        # Web search

# ── OpenRouter (free models: Nano, Core, Build, Vision, Think) ─────────────────
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=****

# ── v0 Platform API (Phase 6 — v0-quality UI generation) ──────────────────────
# Get your key from: https://v0.dev/chat/settings/keys
V0_API_KEY=****

# ── Stripe Billing ─────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_****
STRIPE_WEBHOOK_SECRET=whsec_****

# Create two recurring prices in Stripe dashboard, copy the price IDs:
STRIPE_PRICE_PLUS=price_****   # $5/month subscription
STRIPE_PRICE_PRO=price_****    # $10/month subscription

# Webhook URL to register in Stripe dashboard:
# https://masidy.com/api/billing/webhook
